#include <algorithm>
#include <cstdint>
#include <cstdlib>
#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

constexpr uint32_t OUTPUT_TILE_ROWS = 128;
constexpr uint32_t OUTPUT_BUFFER_BYTES = OUTPUT_TILE_ROWS * sizeof(float);
constexpr uint32_t ROW_PTR_TILE_ROWS = 128;
constexpr uint32_t ROW_PTR_TILE_ELEMS = ROW_PTR_TILE_ROWS + 1;
constexpr uint32_t ROW_PTR_BUFFER_BYTES = ROW_PTR_TILE_ELEMS * sizeof(int32_t);
constexpr uint32_t NNZ_CHUNK_ELEMS = 256;
constexpr uint32_t COL_IDX_BUFFER_BYTES = NNZ_CHUNK_ELEMS * sizeof(int32_t);
constexpr uint32_t VALUES_BUFFER_BYTES = NNZ_CHUNK_ELEMS * sizeof(float);
constexpr uint32_t X_WINDOW_MAX_ELEMS = 512;
constexpr uint32_t X_WINDOW_BUFFER_BYTES = X_WINDOW_MAX_ELEMS * sizeof(float);
constexpr uint32_t kProfileFields = 7;
constexpr uint32_t SHORT_ROW_THRESHOLD = 4;

struct SpmvTilingData {
    uint32_t blockNum;
    uint32_t rows;
    uint32_t cols;
    uint32_t nnz;
    uint32_t rowPtrTileRows;
    uint64_t blockRowRanges;
};

struct SpmvBlockProfile {
    uint32_t rowStart;
    uint32_t rowEnd;
    uint32_t rowCount;
    uint32_t nnzCount;
    uint32_t chunkCount;
    uint32_t useWindowCount;
    uint32_t shortRowCount;
};

class KernelSpmv {
public:
    __aicore__ inline KernelSpmv(AscendC::TPipe* pipe)
    {
        pipe_ = pipe;
    }

    __aicore__ inline void Init(GM_ADDR rowPtr, GM_ADDR colIdx, GM_ADDR values, GM_ADDR x, GM_ADDR y,
                                GM_ADDR profile, const __gm__ SpmvTilingData* tiling)
    {
        tiling_ = tiling;
        blockIdx_ = AscendC::GetBlockIdx();
        blockRowRangesGm_.SetGlobalBuffer((__gm__ uint32_t*)tiling_->blockRowRanges, tiling_->blockNum * 2);
        rowPtrGm_.SetGlobalBuffer((__gm__ int32_t*)rowPtr, tiling_->rows + 1);
        colIdxGm_.SetGlobalBuffer((__gm__ int32_t*)colIdx, tiling_->nnz);
        valuesGm_.SetGlobalBuffer((__gm__ float*)values, tiling_->nnz);
        xGm_.SetGlobalBuffer((__gm__ float*)x, tiling_->cols);
        yGm_.SetGlobalBuffer((__gm__ float*)y, tiling_->rows);
        profileGm_.SetGlobalBuffer((__gm__ uint32_t*)profile, tiling_->blockNum * kProfileFields);
        pipe_->InitBuffer(rowPtrQueue_, 1, ROW_PTR_BUFFER_BYTES);
        pipe_->InitBuffer(colIdxQueue_, 2, COL_IDX_BUFFER_BYTES);
        pipe_->InitBuffer(valuesQueue_, 2, VALUES_BUFFER_BYTES);
        pipe_->InitBuffer(outQueueY_, 1, OUTPUT_BUFFER_BYTES);
        pipe_->InitBuffer(xWindowBuf_, X_WINDOW_BUFFER_BYTES);

        if (blockIdx_ < tiling_->blockNum) {
            const uint32_t rangeBase = blockIdx_ * 2;
            rowStart_ = blockRowRangesGm_.GetValue(rangeBase + 0);
            rowEnd_ = blockRowRangesGm_.GetValue(rangeBase + 1);
        } else {
            rowStart_ = 0;
            rowEnd_ = 0;
        }
        profile_.rowStart = rowStart_;
        profile_.rowEnd = rowEnd_;
        profile_.rowCount = rowEnd_ - rowStart_;
        profile_.nnzCount = 0;
        profile_.chunkCount = 0;
        profile_.useWindowCount = 0;
        profile_.shortRowCount = 0;
    }

    __aicore__ inline void Process()
    {
        if (blockIdx_ >= tiling_->blockNum || rowStart_ >= rowEnd_) {
            WriteProfile();
            return;
        }

        const uint32_t tileRows = tiling_->rowPtrTileRows;
        for (uint32_t rowBase = rowStart_; rowBase < rowEnd_; rowBase += tileRows) {
            const uint32_t rowsThisTile = (rowEnd_ - rowBase) < tileRows ? (rowEnd_ - rowBase) : tileRows;
            CopyInRowPtr(rowBase, rowsThisTile);
            AscendC::LocalTensor<int32_t> rowPtrLocal = rowPtrQueue_.DeQue<int32_t>();
            AscendC::LocalTensor<float> yLocal = outQueueY_.AllocTensor<float>();
            for (uint32_t localRow = 0; localRow < rowsThisTile; ++localRow) {
                yLocal.SetValue(localRow, 0.0f);
            }

            for (uint32_t localRow = 0; localRow < rowsThisTile; ++localRow) {
                const uint32_t row = rowBase + localRow;
                const uint32_t rowNnzStart = static_cast<uint32_t>(rowPtrLocal.GetValue(localRow));
                const uint32_t rowNnzEnd = static_cast<uint32_t>(rowPtrLocal.GetValue(localRow + 1));
                const uint32_t rowNnz = rowNnzEnd - rowNnzStart;
                profile_.nnzCount += rowNnz;

                float sum = 0.0f;
                if (rowNnz <= SHORT_ROW_THRESHOLD) {
                    if (rowNnz > 0) {
                        ++profile_.shortRowCount;
                    }
                    sum = ComputeShortRow(rowNnzStart, rowNnzEnd);
                } else {
                    for (uint32_t chunkStart = rowNnzStart; chunkStart < rowNnzEnd; chunkStart += NNZ_CHUNK_ELEMS) {
                        const uint32_t remainingNnz = rowNnzEnd - chunkStart;
                        const uint32_t chunkElems = remainingNnz < NNZ_CHUNK_ELEMS ? remainingNnz : NNZ_CHUNK_ELEMS;
                        ++profile_.chunkCount;
                        CopyInChunk(static_cast<int32_t>(chunkStart), chunkElems);
                        sum += ComputeChunk(chunkElems);
                    }
                }
                yLocal.SetValue(localRow, sum);
            }

            outQueueY_.EnQue(yLocal);
            CopyOutBatch(rowBase, rowsThisTile);
            rowPtrQueue_.FreeTensor(rowPtrLocal);
        }
        WriteProfile();
    }

private:
    __aicore__ inline void WriteProfile()
    {
        const uint32_t base = blockIdx_ * kProfileFields;
        profileGm_.SetValue(base + 0, profile_.rowStart);
        profileGm_.SetValue(base + 1, profile_.rowEnd);
        profileGm_.SetValue(base + 2, profile_.rowCount);
        profileGm_.SetValue(base + 3, profile_.nnzCount);
        profileGm_.SetValue(base + 4, profile_.chunkCount);
        profileGm_.SetValue(base + 5, profile_.useWindowCount);
        profileGm_.SetValue(base + 6, profile_.shortRowCount);
    }

    __aicore__ inline void CopyInRowPtr(uint32_t rowBase, uint32_t rowsThisTile)
    {
        AscendC::LocalTensor<int32_t> rowPtrLocal = rowPtrQueue_.AllocTensor<int32_t>();
        AscendC::DataCopyPad(rowPtrLocal, rowPtrGm_[rowBase],
            {1, static_cast<uint16_t>((rowsThisTile + 1) * sizeof(int32_t)), 0, 0},
            {false, 0, 0, 0});
        rowPtrQueue_.EnQue(rowPtrLocal);
    }

    __aicore__ inline float ComputeShortRow(uint32_t start, uint32_t end)
    {
        float sum = 0.0f;
        for (uint32_t idx = start; idx < end; ++idx) {
            int32_t col = colIdxGm_.GetValue(idx);
            float value = valuesGm_.GetValue(idx);
            sum += value * xGm_.GetValue(col);
        }
        return sum;
    }

    __aicore__ inline void CopyInChunk(int32_t chunkStart, uint32_t chunkElems)
    {
        AscendC::LocalTensor<int32_t> colLocal = colIdxQueue_.AllocTensor<int32_t>();
        AscendC::LocalTensor<float> valuesLocal = valuesQueue_.AllocTensor<float>();
        AscendC::DataCopyPad(colLocal, colIdxGm_[chunkStart],
            {1, static_cast<uint16_t>(chunkElems * sizeof(int32_t)), 0, 0},
            {false, 0, 0, 0});
        AscendC::DataCopyPad(valuesLocal, valuesGm_[chunkStart],
            {1, static_cast<uint16_t>(chunkElems * sizeof(float)), 0, 0},
            {false, 0, 0, 0});
        colIdxQueue_.EnQue(colLocal);
        valuesQueue_.EnQue(valuesLocal);
    }

    __aicore__ inline float ComputeChunk(uint32_t chunkElems)
    {
        AscendC::LocalTensor<int32_t> colLocal = colIdxQueue_.DeQue<int32_t>();
        AscendC::LocalTensor<float> valuesLocal = valuesQueue_.DeQue<float>();
        float sum = 0.0f;
        int32_t minCol = static_cast<int32_t>(tiling_->cols);
        int32_t maxCol = -1;
        for (uint32_t i = 0; i < chunkElems; ++i) {
            int32_t col = colLocal.GetValue(i);
            minCol = col < minCol ? col : minCol;
            maxCol = col > maxCol ? col : maxCol;
        }

        bool useWindow = false;
        AscendC::LocalTensor<float> xWindowLocal;
        if (maxCol >= minCol) {
            const uint32_t windowElems = static_cast<uint32_t>(maxCol - minCol + 1);
            if (windowElems <= X_WINDOW_MAX_ELEMS) {
                xWindowLocal = xWindowBuf_.Get<float>();
                AscendC::DataCopyPad(xWindowLocal, xGm_[minCol],
                    {1, static_cast<uint16_t>(windowElems * sizeof(float)), 0, 0},
                    {false, 0, 0, 0});
                useWindow = true;
                ++profile_.useWindowCount;
            }
        }

        for (uint32_t i = 0; i < chunkElems; ++i) {
            const int32_t col = colLocal.GetValue(i);
            const float value = valuesLocal.GetValue(i);
            const float xValue = useWindow ? xWindowLocal.GetValue(col - minCol) : xGm_.GetValue(col);
            sum += value * xValue;
        }
        colIdxQueue_.FreeTensor(colLocal);
        valuesQueue_.FreeTensor(valuesLocal);
        return sum;
    }

    __aicore__ inline void CopyOutBatch(uint32_t rowBase, uint32_t rowsThisTile)
    {
        AscendC::LocalTensor<float> yLocal = outQueueY_.DeQue<float>();
        AscendC::DataCopyPad(yGm_[rowBase], yLocal,
            {1, static_cast<uint16_t>(rowsThisTile * sizeof(float)), 0, 0});
        outQueueY_.FreeTensor(yLocal);
    }

private:
    AscendC::TPipe* pipe_;
    const __gm__ SpmvTilingData* tiling_;
    uint32_t blockIdx_;
    uint32_t rowStart_;
    uint32_t rowEnd_;
    SpmvBlockProfile profile_;
    AscendC::GlobalTensor<uint32_t> blockRowRangesGm_;
    AscendC::GlobalTensor<int32_t> rowPtrGm_;
    AscendC::GlobalTensor<int32_t> colIdxGm_;
    AscendC::GlobalTensor<float> valuesGm_;
    AscendC::GlobalTensor<float> xGm_;
    AscendC::GlobalTensor<float> yGm_;
    AscendC::GlobalTensor<uint32_t> profileGm_;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> rowPtrQueue_;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> colIdxQueue_;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> valuesQueue_;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueY_;
    AscendC::TBuf<AscendC::TPosition::VECCALC> xWindowBuf_;
};

extern "C" __global__ __vector__ void spmv_custom(GM_ADDR rowPtr, GM_ADDR colIdx, GM_ADDR values,
                                                    GM_ADDR x, GM_ADDR y, GM_ADDR tiling,
                                                    GM_ADDR profile)
{
    AscendC::TPipe pipe;
    KernelSpmv op(&pipe);
    op.Init(rowPtr, colIdx, values, x, y, profile, (__gm__ SpmvTilingData*)tiling);
    op.Process();
}

int LaunchSpmvKernel(uint32_t blockNum, aclrtStream stream,
                     uintptr_t devRowPtr, uintptr_t devColIdx, uintptr_t devValues,
                     uintptr_t devX, uintptr_t devY, uintptr_t devTiling,
                     uintptr_t devProfile)
{
    spmv_custom<<<blockNum, nullptr, stream>>>(
        (GM_ADDR)devRowPtr, (GM_ADDR)devColIdx, (GM_ADDR)devValues,
        (GM_ADDR)devX, (GM_ADDR)devY, (GM_ADDR)devTiling, (GM_ADDR)devProfile);
    return aclrtSynchronizeStream(stream);
}
