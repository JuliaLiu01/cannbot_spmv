#include <algorithm>
#include <cstdint>
#include <cstdlib>
#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

constexpr uint32_t OUTPUT_TILE_ROWS = 128;
constexpr uint32_t OUTPUT_BUFFER_BYTES = OUTPUT_TILE_ROWS * sizeof(float);
constexpr uint32_t ROW_PTR_TILE_ROWS = 128;
constexpr uint32_t ROW_PTR_TILE_ELEMS = ROW_PTR_TILE_ROWS + 1;
constexpr uint32_t ROW_PTR_BUFFER_BYTES = ROW_PTR_TILE_ELEMS * sizeof(int32_t);
constexpr uint32_t NNZ_CHUNK_ELEMS = 256;
constexpr uint32_t COL_IDX_BUFFER_BYTES = NNZ_CHUNK_ELEMS * sizeof(int32_t);
constexpr uint32_t VALUES_BUFFER_BYTES = NNZ_CHUNK_ELEMS * sizeof(float);
constexpr uint32_t X_WINDOW_MAX_ELEMS = 512;
constexpr uint32_t X_WINDOW_BUFFER_BYTES = X_WINDOW_MAX_ELEMS * sizeof(float);

struct SpmvTilingData {
    uint32_t blockNum;
    uint32_t rows;
    uint32_t cols;
    uint32_t nnz;
    uint32_t rowPtrTileRows;
};

class KernelSpmv {
public:
    __aicore__ inline KernelSpmv(AscendC::TPipe* pipe)
    {
        pipe_ = pipe;
    }

    __aicore__ inline void Init(GM_ADDR rowPtr, GM_ADDR colIdx, GM_ADDR values, GM_ADDR x, GM_ADDR y,
                                const __gm__ SpmvTilingData* tiling)
    {
        tiling_ = tiling;
        blockIdx_ = AscendC::GetBlockIdx();
        uint64_t rowStart64 = static_cast<uint64_t>(tiling_->rows) * blockIdx_ / tiling_->blockNum;
        uint64_t rowEnd64 = static_cast<uint64_t>(tiling_->rows) * (blockIdx_ + 1) / tiling_->blockNum;
        rowStart_ = static_cast<uint32_t>(rowStart64);
        rowEnd_ = static_cast<uint32_t>(rowEnd64);
        rowCount_ = rowEnd_ - rowStart_;

        rowPtrGm_.SetGlobalBuffer((__gm__ int32_t*)rowPtr, tiling_->rows + 1);
        colIdxGm_.SetGlobalBuffer((__gm__ int32_t*)colIdx, tiling_->nnz);
        valuesGm_.SetGlobalBuffer((__gm__ float*)values, tiling_->nnz);
        xGm_.SetGlobalBuffer((__gm__ float*)x, tiling_->cols);
        yGm_.SetGlobalBuffer((__gm__ float*)y, tiling_->rows);
        pipe_->InitBuffer(rowPtrQueue_, 1, ROW_PTR_BUFFER_BYTES);
        pipe_->InitBuffer(colIdxQueue_, 2, COL_IDX_BUFFER_BYTES);
        pipe_->InitBuffer(valuesQueue_, 2, VALUES_BUFFER_BYTES);
        pipe_->InitBuffer(outQueueY_, 2, OUTPUT_BUFFER_BYTES);
        pipe_->InitBuffer(xWindowBuf_, X_WINDOW_BUFFER_BYTES);
    }

    __aicore__ inline void Process()
    {
        if (rowStart_ >= rowEnd_) {
            return;
        }

        uint32_t rowPtrTileRows = tiling_->rowPtrTileRows;
        for (uint32_t rowBase = rowStart_; rowBase < rowEnd_; rowBase += rowPtrTileRows) {
            uint32_t remainingRows = rowEnd_ - rowBase;
            uint32_t rowsThisTile = remainingRows < rowPtrTileRows ? remainingRows : rowPtrTileRows;
            AscendC::LocalTensor<int32_t> rowPtrLocal = CopyInRowPtrTile(rowBase, rowsThisTile);

            AscendC::LocalTensor<float> yLocal = outQueueY_.AllocTensor<float>();
            for (uint32_t i = 0; i < rowsThisTile; ++i) {
                yLocal.SetValue(i, 0.0f);
            }

            for (uint32_t localRow = 0; localRow < rowsThisTile; ++localRow) {
                int32_t start = rowPtrLocal.GetValue(localRow);
                int32_t end = rowPtrLocal.GetValue(localRow + 1);
                float sum = 0.0f;
                for (int32_t chunkStart = start; chunkStart < end; chunkStart += NNZ_CHUNK_ELEMS) {
                    uint32_t remainingNnz = static_cast<uint32_t>(end - chunkStart);
                    uint32_t chunkElems = remainingNnz < NNZ_CHUNK_ELEMS ? remainingNnz : NNZ_CHUNK_ELEMS;
                    CopyInChunk(chunkStart, chunkElems);
                    sum += ComputeChunk(chunkElems);
                }
                yLocal.SetValue(localRow, sum);
            }

            rowPtrQueue_.FreeTensor(rowPtrLocal);
            outQueueY_.EnQue(yLocal);
            CopyOutBatch(rowBase, rowsThisTile);
        }
    }

private:
    __aicore__ inline AscendC::LocalTensor<int32_t> CopyInRowPtrTile(uint32_t rowBase, uint32_t rowsThisTile)
    {
        AscendC::LocalTensor<int32_t> rowPtrLocal = rowPtrQueue_.AllocTensor<int32_t>();
        AscendC::DataCopyPad(rowPtrLocal, rowPtrGm_[rowBase],
            {1, static_cast<uint16_t>((rowsThisTile + 1) * sizeof(int32_t)), 0, 0},
            {false, 0, 0, 0});
        rowPtrQueue_.EnQue(rowPtrLocal);
        return rowPtrQueue_.DeQue<int32_t>();
    }

    __aicore__ inline void CopyInChunk(int32_t chunkStart, uint32_t chunkElems)
    {
        AscendC::LocalTensor<int32_t> colLocal = colIdxQueue_.AllocTensor<int32_t>();
        AscendC::LocalTensor<float> valuesLocal = valuesQueue_.AllocTensor<float>();
        AscendC::DataCopyPad(colLocal, colIdxGm_[chunkStart],
            {1, static_cast<uint16_t>(chunkElems * sizeof(int32_t)), 0, 0},
            {false, 0, 0, 0});
        AscendC::DataCopyPad(valuesLocal, valuesGm_[chunkStart],
            {1, static_cast<uint16_t>(chunkElems * sizeof(float)), 0, 0},
            {false, 0, 0, 0});
        colIdxQueue_.EnQue(colLocal);
        valuesQueue_.EnQue(valuesLocal);
    }

    __aicore__ inline float ComputeChunk(uint32_t chunkElems)
    {
        AscendC::LocalTensor<int32_t> colLocal = colIdxQueue_.DeQue<int32_t>();
        AscendC::LocalTensor<float> valuesLocal = valuesQueue_.DeQue<float>();
        float sum = 0.0f;
        int32_t minCol = static_cast<int32_t>(tiling_->cols);
        int32_t maxCol = -1;
        for (uint32_t i = 0; i < chunkElems; ++i) {
            int32_t col = colLocal.GetValue(i);
            minCol = col < minCol ? col : minCol;
            maxCol = col > maxCol ? col : maxCol;
        }

        bool useWindow = false;
        AscendC::LocalTensor<float> xWindowLocal;
        if (maxCol >= minCol) {
            uint32_t windowElems = static_cast<uint32_t>(maxCol - minCol + 1);
            if (windowElems <= X_WINDOW_MAX_ELEMS) {
                xWindowLocal = xWindowBuf_.Get<float>();
                AscendC::DataCopyPad(xWindowLocal, xGm_[minCol],
                    {1, static_cast<uint16_t>(windowElems * sizeof(float)), 0, 0},
                    {false, 0, 0, 0});
                useWindow = true;
            }
        }

        for (uint32_t i = 0; i < chunkElems; ++i) {
            int32_t col = colLocal.GetValue(i);
            float value = valuesLocal.GetValue(i);
            float xValue = useWindow ? xWindowLocal.GetValue(col - minCol) : xGm_.GetValue(col);
            sum += value * xValue;
        }
        colIdxQueue_.FreeTensor(colLocal);
        valuesQueue_.FreeTensor(valuesLocal);
        return sum;
    }

    __aicore__ inline void CopyOutBatch(uint32_t rowBase, uint32_t rowsThisTile)
    {
        AscendC::LocalTensor<float> yLocal = outQueueY_.DeQue<float>();
        AscendC::DataCopyPad(yGm_[rowBase], yLocal,
            {1, static_cast<uint16_t>(rowsThisTile * sizeof(float)), 0, 0});
        outQueueY_.FreeTensor(yLocal);
    }

private:
    AscendC::TPipe* pipe_;
    const __gm__ SpmvTilingData* tiling_;
    uint32_t blockIdx_;
    uint32_t rowStart_;
    uint32_t rowEnd_;
    uint32_t rowCount_;
    AscendC::GlobalTensor<int32_t> rowPtrGm_;
    AscendC::GlobalTensor<int32_t> colIdxGm_;
    AscendC::GlobalTensor<float> valuesGm_;
    AscendC::GlobalTensor<float> xGm_;
    AscendC::GlobalTensor<float> yGm_;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> rowPtrQueue_;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> colIdxQueue_;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> valuesQueue_;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueY_;
    AscendC::TBuf<AscendC::TPosition::VECCALC> xWindowBuf_;
};

extern "C" __global__ __vector__ void spmv_custom(GM_ADDR rowPtr, GM_ADDR colIdx, GM_ADDR values,
                                                     GM_ADDR x, GM_ADDR y, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    KernelSpmv op(&pipe);
    op.Init(rowPtr, colIdx, values, x, y, (__gm__ SpmvTilingData*)tiling);
    op.Process();
}

struct ArgInfo {
    std::string fileName;
    size_t length;
};

int CheckAclRet(aclError ret, const char* expr)
{
    if (ret != ACL_SUCCESS) {
        std::cerr << expr << " failed, ret=" << ret << std::endl;
        return ret;
    }
    return ACL_SUCCESS;
}

int KernelCall(uint32_t blockNum, aclrtStream stream,
    std::vector<ArgInfo>& inputsInfo, std::vector<ArgInfo>& outputsInfo,
    uint8_t* tilingData)
{
    std::vector<uint8_t*> inputHost(inputsInfo.size(), nullptr);
    std::vector<uint8_t*> inputDevice(inputsInfo.size(), nullptr);
    std::vector<uint8_t*> outputHost(outputsInfo.size(), nullptr);
    std::vector<uint8_t*> outputDevice(outputsInfo.size(), nullptr);
    uint8_t* tilingDevice = nullptr;

    auto ret = aclrtMalloc((void**)&tilingDevice, sizeof(SpmvTilingData), ACL_MEM_MALLOC_HUGE_FIRST);
    if (CheckAclRet(ret, "aclrtMalloc tiling") != ACL_SUCCESS) {
        return ret;
    }
    ret = aclrtMemcpy(tilingDevice, sizeof(SpmvTilingData), tilingData,
        sizeof(SpmvTilingData), ACL_MEMCPY_HOST_TO_DEVICE);
    if (CheckAclRet(ret, "aclrtMemcpy tiling") != ACL_SUCCESS) {
        aclrtFree(tilingDevice);
        return ret;
    }

    for (size_t i = 0; i < inputsInfo.size(); i++) {
        ret = aclrtMallocHost((void**)&inputHost[i], inputsInfo[i].length);
        if (CheckAclRet(ret, "aclrtMallocHost input") != ACL_SUCCESS) {
            aclrtFree(tilingDevice);
            return ret;
        }
        ret = aclrtMalloc((void**)&inputDevice[i], inputsInfo[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
        if (CheckAclRet(ret, "aclrtMalloc input") != ACL_SUCCESS) {
            aclrtFree(tilingDevice);
            return ret;
        }
        if (!ReadFile(inputsInfo[i].fileName, inputsInfo[i].length, inputHost[i], inputsInfo[i].length)) {
            aclrtFree(tilingDevice);
            return ACL_ERROR_FAILURE;
        }
        ret = aclrtMemcpy(inputDevice[i], inputsInfo[i].length, inputHost[i],
            inputsInfo[i].length, ACL_MEMCPY_HOST_TO_DEVICE);
        if (CheckAclRet(ret, "aclrtMemcpy input") != ACL_SUCCESS) {
            aclrtFree(tilingDevice);
            return ret;
        }
    }

    for (size_t i = 0; i < outputsInfo.size(); i++) {
        ret = aclrtMallocHost((void**)&outputHost[i], outputsInfo[i].length);
        if (CheckAclRet(ret, "aclrtMallocHost output") != ACL_SUCCESS) {
            aclrtFree(tilingDevice);
            return ret;
        }
        ret = aclrtMalloc((void**)&outputDevice[i], outputsInfo[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
        if (CheckAclRet(ret, "aclrtMalloc output") != ACL_SUCCESS) {
            aclrtFree(tilingDevice);
            return ret;
        }
    }

    spmv_custom<<<blockNum, nullptr, stream>>>(
        inputDevice[0], inputDevice[1], inputDevice[2], inputDevice[3], outputDevice[0], tilingDevice);
    ret = aclrtSynchronizeStream(stream);
    if (CheckAclRet(ret, "aclrtSynchronizeStream") != ACL_SUCCESS) {
        aclrtFree(tilingDevice);
        return ret;
    }

    ret = aclrtMemcpy(outputHost[0], outputsInfo[0].length, outputDevice[0],
        outputsInfo[0].length, ACL_MEMCPY_DEVICE_TO_HOST);
    if (CheckAclRet(ret, "aclrtMemcpy output") != ACL_SUCCESS) {
        aclrtFree(tilingDevice);
        return ret;
    }
    if (!WriteFile(outputsInfo[0].fileName, outputHost[0], outputsInfo[0].length)) {
        aclrtFree(tilingDevice);
        return ACL_ERROR_FAILURE;
    }

    aclrtFree(tilingDevice);
    for (auto* ptr : inputDevice) {
        if (ptr != nullptr) {
            aclrtFree(ptr);
        }
    }
    for (auto* ptr : inputHost) {
        if (ptr != nullptr) {
            aclrtFreeHost(ptr);
        }
    }
    for (auto* ptr : outputDevice) {
        if (ptr != nullptr) {
            aclrtFree(ptr);
        }
    }
    for (auto* ptr : outputHost) {
        if (ptr != nullptr) {
            aclrtFreeHost(ptr);
        }
    }

    return ACL_SUCCESS;
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t rows = 256;
    uint32_t cols = 512;
    uint32_t nnz = 0;
    if (argc > 1) {
        rows = static_cast<uint32_t>(std::strtoul(argv[1], nullptr, 10));
    }
    if (argc > 2) {
        cols = static_cast<uint32_t>(std::strtoul(argv[2], nullptr, 10));
    }
    if (argc > 3) {
        nnz = static_cast<uint32_t>(std::strtoul(argv[3], nullptr, 10));
    }

    auto ret = aclInit(nullptr);
    if (CheckAclRet(ret, "aclInit") != ACL_SUCCESS) {
        return ret;
    }

    int32_t deviceId = 0;
    ret = aclrtSetDevice(deviceId);
    if (CheckAclRet(ret, "aclrtSetDevice") != ACL_SUCCESS) {
        aclFinalize();
        return ret;
    }

    int64_t availableCoreNum = 0;
    ret = aclrtGetDeviceInfo(deviceId, ACL_DEV_ATTR_VECTOR_CORE_NUM, &availableCoreNum);
    if (CheckAclRet(ret, "aclrtGetDeviceInfo") != ACL_SUCCESS) {
        aclrtResetDevice(deviceId);
        aclFinalize();
        return ret;
    }

    SpmvTilingData tiling {};
    tiling.rows = rows;
    tiling.cols = cols;
    tiling.nnz = nnz;
    tiling.blockNum = std::max<uint32_t>(1, static_cast<uint32_t>(availableCoreNum));
    tiling.rowPtrTileRows = ROW_PTR_TILE_ROWS;

    std::vector<ArgInfo> inputsInfo = {
        {"./input/row_ptr.bin", static_cast<size_t>(rows + 1) * sizeof(int32_t)},
        {"./input/col_idx.bin", static_cast<size_t>(nnz) * sizeof(int32_t)},
        {"./input/values.bin", static_cast<size_t>(nnz) * sizeof(float)},
        {"./input/x.bin", static_cast<size_t>(cols) * sizeof(float)},
    };
    std::vector<ArgInfo> outputsInfo = {
        {"./output/output.bin", static_cast<size_t>(rows) * sizeof(float)},
    };

    aclrtStream stream = nullptr;
    ret = aclrtCreateStream(&stream);
    if (CheckAclRet(ret, "aclrtCreateStream") != ACL_SUCCESS) {
        aclrtResetDevice(deviceId);
        aclFinalize();
        return ret;
    }

    ret = KernelCall(tiling.blockNum, stream, inputsInfo, outputsInfo, (uint8_t*)&tiling);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return ret;
}
